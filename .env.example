# ─────────────────────────────────────────────
#  Discord Bot – Environment Variables Template
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Discord ──────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# ── Guild / Server ────────────────────────────
# Comma-separated guild IDs for slash command sync (leave blank for global)
GUILD_IDS=

# ── Prefix ───────────────────────────────────
COMMAND_PREFIX=/

# ── Bot Settings ─────────────────────────────
BOT_OWNER_ID=your_discord_user_id_here

# ── Slash Command Group ───────────────────────
# Namespace all slash commands under a group to avoid clashing with other bots.
# e.g. COMMAND_GROUP=gk  →  /gk help, /gk ping, /gk kick
# Leave blank for bare top-level commands  (/help, /ping, /kick)
COMMAND_GROUP=g

# ── Feature Flags ────────────────────────────
# Set to false to disable all moderation commands (kick, ban, mute, etc.)
ENABLE_MOD_COMMANDS=true

# ── Firebase / Firestore ─────────────────────
# Path to your Firebase service account JSON key file
# Get this from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_CREDENTIALS=firebase-key.json

# ── Firebase Storage ─────────────────────────
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# ── Gemini AI ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Logging ──────────────────────────────────
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR
