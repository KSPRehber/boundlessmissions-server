# ─────────────────────────────────────────────
#  Discord Bot – Environment Variables Template
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Discord ──────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# ── Guild / Server ────────────────────────────
# Comma-separated guild IDs for slash command sync (leave blank for global)
GUILD_IDS=

# ── Prefix ───────────────────────────────────
COMMAND_PREFIX=/

# ── Bot Settings ─────────────────────────────
BOT_OWNER_ID=your_discord_user_id_here

# ── Slash Command Group ───────────────────────
# Namespace all slash commands under a group to avoid clashing with other bots.
# e.g. COMMAND_GROUP=gk  →  /gk help, /gk ping, /gk kick
# Leave blank for bare top-level commands  (/help, /ping, /kick)
COMMAND_GROUP=g

# ── Feature Flags ────────────────────────────
# Set to false to disable all moderation commands (kick, ban, mute, etc.)
ENABLE_MOD_COMMANDS=true

# ── Firebase / Firestore ─────────────────────
# Path to your Firebase service account JSON key file
# Get this from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_CREDENTIALS=firebase-key.json

# ── Firebase Storage ─────────────────────────
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# ── Gemini AI ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── KSP API Server ───────────────────────────
# REST API for KSP mod ↔ Discord bridge (runs in-process with the bot)
KSP_API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=5022
# REQUIRED when KSP_API_ENABLED=true. Signs KSP session tokens — a known/default
# value lets anyone forge a login for any user, so the bot refuses to start with
# a placeholder. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
API_SECRET_KEY=your_random_secret_here
# Discord DM login approval for KSP linking. On by default. Set to false to skip
# the approval step while testing.
KSP_2FA_ENABLED=true
# Device binding: bind each install's random device id to the account and block
# any other device (e.g. a copied session token) until approved from Discord.
# On by default. Set to false to disable. Note: collecting MAC/IP/KSP.log in the
# moderation report requires disclosure in your ToS/Privacy Policy.
KSP_DEVICE_BINDING_ENABLED=true
# Mod version gate. On by default. The KSP client reports its DLL's SHA256 and the
# server blocks outdated clients in-game until they update. Publish a version with
# the /admin publishversion command. Set to false to disable the gate entirely.
# (With no version published yet, nothing is ever blocked regardless of this flag.)
KSP_VERSION_CHECK_ENABLED=true
# ── Public deployment (leave blank for localhost) ──
# Behind a TLS-terminating reverse proxy (recommended): list the proxy's IP so
# the real client IP is read from X-Forwarded-For for rate limiting, and bind the
# API to localhost (API_HOST=127.0.0.1) so only the proxy can reach it.
API_TRUSTED_PROXIES=
# Direct HTTPS without a proxy: set BOTH to a cert and key (PEM). Leave blank to
# serve plain HTTP (localhost, or when a proxy terminates TLS).
API_SSL_CERTFILE=
API_SSL_KEYFILE=

# ── Logging ──────────────────────────────────
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR
